@page
@model LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - SaigonRide</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <!-- Chỉ gọi 1 file CSS gộp (giả sử tên là site.css) -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <div class="full-page-wrapper">
        <div class="main-card">
            
            <!-- THÊM class welcome-dark-panel vào đây -->
            <div class="side-welcome welcome-dark-panel login-welcome-half">
                <h1 class="fw-bold mb-3">Welcome to<br>SaiGonRide!</h1>
                <div class="bike-icon">
                    <i class="bi bi-bicycle" style="font-size: 100px;"></i>
                </div>
                <div class="lightning-bolt">
                    <i class="bi bi-lightning-charge-fill" style="font-size: 30px;"></i>
                </div>
            </div>

            <div class="side-login">
                <h1 class="login-title">Login</h1>
                
                <div class="register-link-wrapper">
                    <p class="text-muted">
                        Don't have an account?
                        <a asp-page="./Register" class="register-link">Register here</a>
                    </p>
                </div>
            
                <form id="loginForm" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <div class="custom-input-group">
                        <input asp-for="Input.Username" placeholder="Username" />
                        <i class="bi bi-person"></i>
                    </div>

                    <div class="custom-input-group">
                        <input asp-for="Input.Password" type="password" placeholder="Password" />
                        <i class="bi bi-lock"></i>
                    </div>

                    <button type="submit" class="btn btn-login-action w-100">Login</button>
                </form>
            </div>

        </div>
    </div>
</body>
</html>