@page
@model RegisterModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registration - SaigonRide</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body>

    <div class="full-page-wrapper">
        <!-- Bỏ các class chia cột của Bootstrap, để Flexbox tự lo -->
        <div class="main-card">
            
            <!-- Đổi thành regis-form-half -->
            <div class="regis-form-half">
                <h1 class="regis-title">Registration</h1>
                
                <div class="login-link-wrapper">
                    <p class="text-muted">
                        Already have an account?
                        <a asp-page="./Login" class="login-link">Login here</a>
                    </p>
                </div>
            
                <form id="registerForm" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <div class="custom-input-group">
                        <input asp-for="Input.Username" placeholder="Username" />
                        <i class="bi bi-person"></i>
                    </div>

                    <div class="custom-input-group">
                        <input asp-for="Input.Email" placeholder="Email" />
                        <i class="bi bi-envelope"></i>
                    </div>

                    <div class="custom-input-group">
                        <input asp-for="Input.Password" type="password" placeholder="Password" />
                        <i class="bi bi-lock"></i>
                    </div>

                    <button type="submit" class="btn btn-register-action w-100">Registration</button>
                </form>
            </div>

            <!-- Đổi thành regis-welcome-half và thêm welcome-dark-panel -->
            <div class="regis-welcome-half welcome-dark-panel">
                <h1 class="fw-bold mb-3">Welcome to<br>SaiGonRide!</h1>
                <div class="bike-icon">
                    <i class="bi bi-bicycle" style="font-size: 100px;"></i>
                </div>
                <div class="lightning-bolt">
                    <i class="bi bi-lightning-charge-fill" style="font-size: 30px;"></i>
                </div>
            </div>

        </div>
    </div>
</body>
</html>