@model List<Coupon>
@{

    ViewData["Title"] = "Settings";
}

<div class="settings-wrapper">

    <div class="settings-col">
        <div class="st-card text-center profile-card">
            <img src="https://i.pravatar.cc/150?img=47" alt="Profile Avatar" class="profile-img" />
            <h3 class="profile-name">&#64;User-Name</h3>
            <p class="profile-email">user&#64;email.com</p>
        </div>

        <div class="st-card info-card">
            <h4 class="st-card-title">Information</h4>
            <ul class="info-list">
                <li><strong>Name:</strong> <span>Name, Last Name</span></li>
                <li><strong>Email:</strong> <span>user&#64;email.com</span></li>
                <li><strong>Tel:</strong> <span>+51 966 696 123</span></li>
            </ul>
        </div>

        <div class="mt-3 text-center">
            <!-- Thêm asp-route-returnUrl để chỉ định trang sẽ quay về sau khi thoát -->
            <form asp-area="Identity" asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
                  method="post">
                <button type="submit" class="btn-logout-red w-100">
                    Log out
                </button>
            </form>
        </div>
    </div>


    <div class="settings-col col-main">
        <div class="st-card h-100 form-card">
            <h3 class="st-section-title">User Settings</h3>
            <div class="form-section">
                <h4 class="st-card-title">Details</h4>
                <div class="form-grid">
                    <div class="form-group">
                        <label>Name</label>
                        <input type="text" placeholder="Pepito Rodrick ..." />
                    </div>

                    <div class="form-group">
                        <label>Last Name</label>
                        <input type="text" placeholder="Coronel Sifuentes ..." />
                    </div>

                    <div class="form-group">
                        <label>Email</label>
                        <!-- Đã đổi thành @@uni.pe để Razor không tưởng đây là biến C# -->
                        <input type="email" placeholder="pepito.c.sifuentes@@uni.pe" />
                    </div>

                    <div class="form-group">
                        <label>Tel - Number:</label>
                        <div class="phone-input-group">
                            <input type="text" class="input-prefix" value="+51" readonly />
                            <input type="text" class="input-phone" placeholder="969 123 456" />
                        </div>
                    </div>
                </div>
                <button class="btn-neon">Save changes</button>
            </div>

            <div class="form-section mt-5">
                <h4 class="st-card-title">Password</h4>
                <div class="form-grid">
                    <div class="form-group">
                        <label>Change password</label>
                        <input type="password" placeholder="Put your password..." />
                    </div>

                    <div class="form-group">
                        <label class="invisible-label">Confirm password</label>
                        <input type="password" placeholder="Confirm password..." />
                    </div>

                    <div class="form-group">
                        <label>New password</label>
                        <input type="password" placeholder="Put your new password..." />
                    </div>

                    <div class="form-group">
                        <label class="invisible-label">Confirm new</label>
                        <input type="password" placeholder="Confirm new password..." />
                    </div>
                </div>

                <div class="form-actions">
                    <button class="btn-neon">Save changes</button>
                    <button class="btn-transparent">Forgot your password?</button>
                </div>
            </div>
        </div>
    </div>

    <div class="settings-col wallet-col">
        <div class="wallet-widget">
            <div class="wallet-header">
                <h2>My Wallet</h2>
                <span class="coin-badge">⭐ 2500</span>
            </div>


            <div class="wallet-inner-card">
                <div class="wallet-type">
                    <div class="icon-cash">$</div>
                    <div class="type-info">
                        <strong>Cash</strong>
                        <p>Default Payment Method</p>
                    </div>
                </div>

                <div class="wallet-balance-row">
                    <div class="balance-left">
                        <span>BALANCE</span>
                        <h2 class="text-red">$2500</h2>
                    </div>

                    <div class="balance-right">
                        <span>EXPIRES</span>
                        <h4>09/21</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="wallet-menu">
            <div class="menu-item">
                <span>Payment Methods</span>
                <span class="arrow">&gt;</span>
            </div>

            <!-- Sửa: Bỏ data-bs-toggle để không hiện Modal, thêm id để bắt sự kiện JS -->
            <div class="menu-item" id="toggleCouponList" style="cursor: pointer;">
                <span>Coupon</span>
                <span class="menu-value">
                    @(Model?.Count ?? 0) <span class="arrow" id="couponArrow">&gt;</span>
                </span>
            </div>

            <!-- Thêm vùng hiện danh sách Coupon ẩn -->
            <div id="couponListDisplay" style="display: none; padding: 10px; background: #1a1b2f; border-radius: 8px; margin-top: 5px;">
                @if (Model != null && Model.Any())
                {
                    foreach (var cp in Model)
                    {
                        <div style="border-bottom: 1px solid #333; padding: 5px 0; color: #cbfb45;">
                            <strong>@cp.Code</strong>: -@cp.DiscountValue.ToString("#,##0") VND
                        </div>
                    }
                }
                else
                {
                    <p style="color: #666; font-size: 0.9rem;">No coupons available.</p>
                }
            </div>

            <div class="menu-item">
                <span>Integral Mall</span>
                <span class="menu-value">4500 <span class="arrow">&gt;</span></span>
            </div>
        </div>
    </div>
</div>



@section Styles {
    <link rel="stylesheet" href="~/css/settings.css" asp-append-version="true" />
}
@section Scripts {
    <script>
        // Hiệu ứng bấm vào Coupon thì hiện danh sách ngay bên dưới
        $('#toggleCouponList').click(function() {
            $('#couponListDisplay').slideToggle();
            // Xoay cái mũi tên cho đẹp
            $('#couponArrow').toggleClass('rotate-90');
        });
    </script>
}

@* Truyền danh sách Coupon vào AvailableCoupons của ViewModel để Modal hiển thị được *@
<partial name="/Views/Payment/_PaymentModal.cshtml" 
         model='new FinalProject__SaigonRide.Models.PaymentViewModel { 
                    AvailableCoupons = Model, 
                    EstimatedCost = 2500 
                }' />