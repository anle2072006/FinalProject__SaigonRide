<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Admin | SaiGonRide</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <style>
        /* ── Reset & base ── */
        *, *::before, *::after { box-sizing: border-box; }
        html, body {
            height: 100%;
            margin: 0;
            background: #0d0f1e;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: white;
        }

        /* ── Shell: sidebar + main ── */
        .admin-shell {
            display: flex;
            min-height: 100vh;
        }

        /* ─────────── SIDEBAR ─────────── */
        .admin-sidebar {
            width: 240px;
            flex-shrink: 0;
            background: #1B1D2F;
            display: flex;
            flex-direction: column;
            padding: 0;
            border-right: 1px solid #2c2e3e;
            position: sticky;
            top: 0;
            height: 100vh;
        }

        .admin-brand {
            padding: 28px 24px 24px;
            border-bottom: 1px solid #2c2e3e;
        }
        .admin-brand .logo-label {
            font-size: 0.68rem;
            color: #8a8a9e;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 4px;
        }
        .admin-brand .logo-name {
            color: #d4ff00;
            font-size: 1.35rem;
            font-weight: 800;
            font-style: italic;
            line-height: 1;
        }
        .admin-brand .logo-badge {
            display: inline-block;
            background: rgba(212,255,0,0.12);
            color: #d4ff00;
            font-size: 0.68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-radius: 4px;
            padding: 2px 7px;
            margin-top: 6px;
        }

        .admin-nav {
            padding: 20px 0;
            flex: 1;
            overflow-y: auto;
        }
        .admin-nav-section {
            padding: 6px 20px 4px;
            color: #3e4060;
            font-size: 0.68rem;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            margin-top: 8px;
        }
        .admin-nav a {
            display: flex;
            align-items: center;
            gap: 11px;
            padding: 11px 20px;
            margin: 2px 10px;
            border-radius: 10px;
            color: #8a8a9e;
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
            transition: all 0.2s;
            border: 1px solid transparent;
        }
        .admin-nav a:hover {
            background: rgba(212,255,0,0.08);
            color: #d4ff00;
            border-color: rgba(212,255,0,0.15);
        }
        .admin-nav a.active {
            background: #d4ff00;
            color: #1a1a2e;
            font-weight: 700;
            border-color: transparent;
        }
        .admin-nav a .nav-icon {
            width: 18px;
            text-align: center;
            font-size: 1rem;
            flex-shrink: 0;
        }

        /* Back to site button */
        .admin-back {
            padding: 16px 20px;
            border-top: 1px solid #2c2e3e;
        }
        .admin-back a {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #8a8a9e;
            text-decoration: none;
            font-size: 0.85rem;
            padding: 10px 14px;
            border-radius: 10px;
            border: 1px solid #2c2e3e;
            transition: all 0.2s;
        }
        .admin-back a:hover {
            color: white;
            border-color: #8a8a9e;
            background: #2c2e3e;
        }

        /* ─────────── MAIN CONTENT ─────────── */
        .admin-main {
            flex: 1;
            background: #0d0f1e;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* Top bar */
        .admin-topbar {
            height: 60px;
            background: #1B1D2F;
            border-bottom: 1px solid #2c2e3e;
            display: flex;
            align-items: center;
            padding: 0 30px;
            gap: 12px;
            flex-shrink: 0;
        }
        .admin-topbar .page-title {
            font-size: 0.95rem;
            font-weight: 600;
            color: white;
        }
        .admin-topbar .breadcrumb-sep {
            color: #3e4060;
            font-size: 1rem;
        }
        .admin-topbar .breadcrumb-cur {
            color: #d4ff00;
            font-size: 0.9rem;
        }
        .admin-topbar .spacer { flex: 1; }
        .admin-topbar .admin-avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: rgba(212,255,0,0.15);
            border: 2px solid #d4ff00;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.8rem;
            color: #d4ff00;
            font-weight: 700;
        }

        /* Page body */
        .admin-body {
            flex: 1;
            padding: 32px 36px;
            overflow-y: auto;
        }
    </style>
</head>
<body>
<div class="admin-shell">

    <!-- ── Sidebar ── -->
    <aside class="admin-sidebar">
        <div class="admin-brand">
            <div class="logo-label">Control Panel</div>
            <div class="logo-name">SaiGonRide</div>
            <span class="logo-badge">Admin</span>
        </div>

        <nav class="admin-nav">
            <div class="admin-nav-section">Overview</div>
            <a asp-controller="Admin" asp-action="Index"
               class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                <span class="nav-icon">📊</span> Dashboard
            </a>

            <div class="admin-nav-section">Manage</div>
            <a asp-controller="Admin" asp-action="Vehicles"
               class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Vehicles" ? "active" : "")">
                <span class="nav-icon">🚲</span> Vehicles
            </a>
            <a asp-controller="Admin" asp-action="Stations"
               class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Stations" ? "active" : "")">
                <span class="nav-icon">🗺️</span> Stations
            </a>
        </nav>

        <div class="admin-back">
            <a asp-controller="Home" asp-action="Index">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                </svg>
                Back to Site
            </a>
        </div>
    </aside>

    <!-- ── Main ── -->
    <div class="admin-main">
        <header class="admin-topbar">
            <span class="page-title">Admin</span>
            <span class="breadcrumb-sep">›</span>
            <span class="breadcrumb-cur">@ViewData["Title"]</span>
            <div class="spacer"></div>
            <div class="admin-avatar">A</div>
        </header>

        <div class="admin-body">
            @RenderBody()
        </div>
    </div>

</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
