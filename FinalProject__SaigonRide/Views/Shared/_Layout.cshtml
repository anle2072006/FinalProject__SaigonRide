<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FinalProject__SaigonRide</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FinalProject__SaigonRide.styles.css" asp-append-version="true" />
</head>
<body>   
    <div class="container-fluid">
        <div class="row">
            <nav id="left-sidebar" class="col-md-2 d-none d-md-block sidebar-dark">
                <div class="sidebar-sticky">
                    <h3 class="brand-name">SaigonRide</h3>
                    <ul class="nav flex-column" id="sidebar">
                        <li class="nav-item">
                            <a class="nav-link" href="#">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Vehicle</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Station</a>
                        </li>
                    </ul>
                </div>
            </nav>

            <main role="main" class="col-md-7 px-md-4 main-content">
                @RenderBody()
            </main>

            <aside id="right-container" class="col-md-3 sidebar-dark">
            </aside>
        </div>
    </div>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
