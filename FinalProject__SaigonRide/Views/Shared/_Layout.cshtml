@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FinalProject__SaiGonRide</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FinalProject__SaiGonRide.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <nav id="left-sidebar" class="col-md-2 d-none d-md-block sidebar-dark">
                <div class="sidebar-top-content">
                    <h3 class="brand-name">SaiGonRide</h3>
                    <ul class="nav flex-column" id="sidebar">
                        <li class="nav-item">
                            <a class="nav-link border-item" asp-controller="Home" asp-action="Index">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link border-item" asp-controller="Stations" asp-action="IndexStations">Station</a>
                        </li>

                        @if (SignInManager.IsSignedIn(User))
                        {
                            /* Chỉ hiện 3 nút này khi ĐÃ đăng nhập */
                            <li class="nav-item">
                                <a class="nav-link border-item" asp-controller="InUse" asp-action="IndexInUse">In Use</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link border-item" asp-controller="History" asp-action="IndexHistory">History</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link border-item" asp-controller="Setting" asp-action="IndexSetting">Setting</a>
                            </li>
                        }
                    </ul>
                </div>

                <!-- FIX 1: Chỉ hiện nút Login/Register nếu CHƯA đăng nhập[cite: 2, 3] -->
                @if (!SignInManager.IsSignedIn(User))
                {
                    <ul class="nav flex-column mb-4 px-3 sidebar-bottom-content">
                        <li class="nav-item">
                            <a class="nav-link auth-btn-outline" asp-area="Identity" asp-page="/Account/Login">Login</a>
                        </li>
                        <li class="nav-item mt-2">
                            <a class="nav-link auth-btn-solid" asp-area="Identity" asp-page="/Account/Register">Create Account</a>
                        </li>
                    </ul>
                }
            </nav>

            <main role="main" class="col-md-7 px-md-4 main-content" style="position: relative;">
                @if (SignInManager.IsSignedIn(User) && ViewData["Title"]?.ToString() == "Dashboard")
                {
                    <div class="dashboard-user-greeting">
                        HELLO @(User.Identity?.Name?.Split('@')[0].ToUpper() ?? "RIDER")!
                    </div>
                }
                @RenderBody()
            </main>

            <aside id="right-container" class="col-md-3 sidebar-dark">
                @RenderSection("RightContent", required: false)
            </aside>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>