@{
    ViewData["Title"] = "Admin Dashboard";
}

@section Styles {
    <style>
        .admin-dashboard-title {
            color: #d4ff00;
            font-weight: 700;
            font-size: 1.8rem;
            margin-bottom: 6px;
        }
        .admin-dashboard-subtitle {
            color: #8a8a9e;
            font-size: 0.9rem;
            margin-bottom: 32px;
        }
        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 36px;
        }
        .dash-card {
            background: #1B1D2F;
            border: 1px solid #2c2e3e;
            border-radius: 16px;
            padding: 24px;
            transition: border-color 0.25s, transform 0.2s;
        }
        .dash-card:hover {
            border-color: #d4ff00;
            transform: translateY(-3px);
        }
        .dash-card .icon {
            font-size: 2rem;
            margin-bottom: 12px;
        }
        .dash-card .count {
            font-size: 2.4rem;
            font-weight: 800;
            color: #d4ff00;
            line-height: 1;
        }
        .dash-card .label {
            color: #8a8a9e;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            margin-top: 6px;
        }
        .nav-section-title {
            color: #8a8a9e;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 12px;
        }
        .nav-links {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .dash-nav-btn {
            background: #1B1D2F;
            border: 1px solid #2c2e3e;
            border-radius: 12px;
            padding: 16px 20px;
            color: white;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 14px;
            font-size: 0.95rem;
            font-weight: 600;
            transition: all 0.2s;
        }
        .dash-nav-btn:hover {
            background: #d4ff00;
            color: #1a1a2e;
            border-color: #d4ff00;
        }
        .dash-nav-btn .icon-circle {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            background: rgba(212,255,0,0.12);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            flex-shrink: 0;
        }
        .dash-nav-btn:hover .icon-circle {
            background: rgba(26,26,46,0.2);
        }
        .dash-nav-btn .arrow {
            margin-left: auto;
            color: #8a8a9e;
        }
        .dash-nav-btn:hover .arrow { color: #1a1a2e; }
    </style>
}

<div class="admin-dashboard-title">🛠️ Admin Panel</div>
<div class="admin-dashboard-subtitle">Tổng quan và điều hướng quản lý hệ thống SaiGonRide</div>

<div class="dashboard-grid">
    <div class="dash-card">
        <div class="icon">🚲</div>
        <div class="count">@ViewBag.VehicleCount</div>
        <div class="label">Vehicles</div>
    </div>
    <div class="dash-card">
        <div class="icon">🗺️</div>
        <div class="count">@ViewBag.StationCount</div>
        <div class="label">Stations</div>
    </div>
    <div class="dash-card">
        <div class="icon">📋</div>
        <div class="count">@ViewBag.BookingCount</div>
        <div class="label">Bookings</div>
    </div>
</div>

<div class="nav-section-title">Quản lý dữ liệu</div>
<div class="nav-links">
    <a class="dash-nav-btn" asp-controller="Admin" asp-action="Vehicles">
        <div class="icon-circle">🚲</div>
        Quản lý Vehicles
        <span class="arrow">›</span>
    </a>
    <a class="dash-nav-btn" asp-controller="Admin" asp-action="Stations">
        <div class="icon-circle">🗺️</div>
        Quản lý Stations
        <span class="arrow">›</span>
    </a>
</div>
