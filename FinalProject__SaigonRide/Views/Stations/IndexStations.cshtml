@{
    ViewData["Title"] = "Station Management";
}

<div class="main-content">
    <div class="header">
        <input type="text" placeholder="Search..." />
        <button type="button">Search</button>
    </div>

    <div class="grid">
        @* Trạm 1 *@
        <div class="card">
            <img src="/images/benthanh.jpg" alt="Ben Thanh" />
            <div class="info">
                <h3>Ben Thanh</h3>
                <p>District 1</p>
            </div>
            <a href="@Url.Action("IndexVehicles", "Vehicles", new { stationId = "ST-01", stationName = "Ben Thanh" })" class="btn-choose">Choose</a>
        </div>

        @* Trạm 2 *@
        <div class="card">
            <img src="/images/bason.jpg" alt="Ba Son" />
            <div class="info">
                <h3>Ba Son</h3>
                <p>District 1</p>
            </div>
            <a href="@Url.Action("IndexVehicles", "Vehicles", new { stationId = "ST-02", stationName = "Ba Son" })" class="btn-choose">Choose</a>
        </div>

        @* Trạm 3 *@
        <div class="card">
            <img src="/images/saigon.jpg" alt="Sai Gon" />
            <div class="info">
                <h3>Sai Gon</h3>
                <p>District 3</p>
            </div>
            <a href="@Url.Action("IndexVehicles", "Vehicles", new { stationId = "ST-03", stationName = "Sai Gon" })" class="btn-choose">Choose</a>
        </div>

        @* Trạm 4 *@
        <div class="card">
            <img src="/images/vanthanh.jpeg" alt="Van Thanh" />
            <div class="info">
                <h3>Van Thanh</h3>
                <p>Binh Thanh</p>
            </div>
            <a href="@Url.Action("IndexVehicles", "Vehicles", new { stationId = "ST-04", stationName = "Van Thanh" })" class="btn-choose">Choose</a>
        </div>

        @* Trạm 5 *@
        <div class="card">
            <img src="/images/thaodien.jpg" alt="Thao Dien" />
            <div class="info">
                <h3>Thao Dien</h3>
                <p>Thu Duc</p>
            </div>
            <a href="@Url.Action("IndexVehicles", "Vehicles", new { stationId = "ST-05", stationName = "Thao Dien" })" class="btn-choose">Choose</a>
        </div>

        @* Trạm 6 *@
        <div class="card">
            <img src="/images/anphu.jpg" alt="An Phu" />
            <div class="info">
                <h3>An Phu</h3>
                <p>Thu Duc</p>
            </div>
            <a href="@Url.Action("IndexVehicles", "Vehicles", new { stationId = "ST-06", stationName = "An Phu" })" class="btn-choose">Choose</a>
        </div>
    </div>
</div>

@section RightContent {
    <h5 class="right-panel-title" style="color: #D1F366; font-weight: bold;">Station Sidebar</h5>
    <p>Thông tin phụ của Station nằm ở bên phải này.</p>
}

@section Styles {
    <link rel="stylesheet" href="~/css/station.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/station.js" asp-append-version="true"></script>
}